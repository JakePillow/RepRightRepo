from __future__ import annotations

import argparse
import json
from pathlib import Path
from typing import Any, Dict, List, Optional, Tuple

import numpy as np

VALID_EXERCISES = ["bench", "squat", "curl", "deadlift"]


# --------- helpers ---------
def _load_meta_fps(meta_path: Path, default: float = 30.0) -> float:
    if meta_path.exists():
        try:
            m = json.loads(meta_path.read_text(encoding="utf-8"))
            fps = m.get("fps", None)
            if isinstance(fps, (int, float)) and fps > 1:
                return float(fps)
        except Exception:
            pass
    return float(default)


def _interp_nans_1d(x: np.ndarray) -> np.ndarray:
    x = x.astype(float)
    n = x.shape[0]
    idx = np.arange(n)
    good = np.isfinite(x)
    if good.sum() == 0:
        return x
    if good.sum() == n:
        return x
    x[~good] = np.interp(idx[~good], idx[good], x[good])
    return x


def _moving_average(x: np.ndarray, win: int) -> np.ndarray:
    if win <= 1:
        return x
    win = int(win)
    w = np.ones(win, dtype=float) / win
    return np.convolve(x, w, mode="same")


def _normalize_robust(x: np.ndarray) -> Tuple[np.ndarray, float]:
    """Return normalized x and robust scale (p95-p5)."""
    p5 = float(np.nanpercentile(x, 5))
    p95 = float(np.nanpercentile(x, 95))
    scale = max(p95 - p5, 1e-9)
    return (x - p5) / scale, scale


def build_signal(pose: np.ndarray, exercise: str) -> np.ndarray:
    """
    Build a 1-D motion signal per exercise from pose array:
      pose: (T, 33, 4)  [x,y,z,visibility] in image coordinates

    Fixes:
      - visibility gating (drop low-confidence landmarks)
      - weighted average for symmetric landmarks
      - fallback landmarks when primary landmarks are missing
    """
    # MediaPipe indices (33 landmarks)
    L_WRIST, R_WRIST = 15, 16
    L_HIP, R_HIP = 23, 24
    L_SHOULDER, R_SHOULDER = 11, 12

    VIS_TH = 0.50  # trust threshold

    def weighted_mean_y(idxs: List[int]) -> np.ndarray:
        y = pose[:, idxs, 1].astype(float)          # (T,K)
        v = pose[:, idxs, 3].astype(float)          # (T,K)
        y[v < VIS_TH] = np.nan
        v[v < VIS_TH] = np.nan
        # weights by visibility
        num = np.nansum(y * v, axis=1)
        den = np.nansum(v, axis=1)
        out = num / den
        out[~np.isfinite(out)] = np.nan
        return out

    if exercise in ("bench", "curl"):
        # wrists usually best proxy; fallback to shoulders if wrists are missing
        y = weighted_mean_y([L_WRIST, R_WRIST])
        if np.isnan(y).mean() > 0.40:
            y = weighted_mean_y([L_SHOULDER, R_SHOULDER])

    elif exercise in ("squat", "deadlift"):
        # hips are primary; fallback to shoulders if hips are missing
        y = weighted_mean_y([L_HIP, R_HIP])
        if np.isnan(y).mean() > 0.35:
            y2 = weighted_mean_y([L_SHOULDER, R_SHOULDER])
            # blend if shoulders are better
            if np.isnan(y2).mean() < np.isnan(y).mean():
                y = y2
        # IMPORTANT: image y grows downward; invert so "standing up" becomes a peak
        y = -y

    else:
        raise ValueError(f"Unknown exercise: {exercise}")

    y = _interp_nans_1d(y)
    return y


def _find_peaks_simple(x: np.ndarray, min_dist: int, min_prom: float) -> List[int]:
    """
    Simple peak finder without scipy:
    - local maxima
    - must exceed neighbors by min_prom in normalized units
    - enforce minimum distance between peaks
    """
    n = len(x)
    if n < 3:
        return []

    # local maxima candidates
    cands = []
    for i in range(1, n - 1):
        if x[i] > x[i - 1] and x[i] >= x[i + 1]:
            # prominence-ish: compare to local neighborhood min
            left = max(0, i - min_dist)
            right = min(n, i + min_dist + 1)
            local_min = float(np.min(x[left:right]))
            if (x[i] - local_min) >= min_prom:
                cands.append(i)

    # enforce min distance: greedy keep highest peaks first
    cands = sorted(cands, key=lambda i: x[i], reverse=True)
    kept: List[int] = []
    for i in cands:
        if all(abs(i - k) >= min_dist for k in kept):
            kept.append(i)

    return sorted(kept)


def _nearest_trough_left(x: np.ndarray, peak_i: int, search: int) -> int:
    left = max(0, peak_i - search)
    seg = x[left:peak_i + 1]
    return left + int(np.argmin(seg))


def _nearest_trough_right(x: np.ndarray, peak_i: int, search: int) -> int:
    right = min(len(x) - 1, peak_i + search)
    seg = x[peak_i:right + 1]
    return peak_i + int(np.argmin(seg))


def compute_rep_metrics(signal: np.ndarray, fps: float, exercise: str) -> Dict[str, Any]:
    """
    Rep detection using hysteresis band-crossing + full-cycle enforcement.

    Why this works better than naive peak counting:
      - avoids double-counting "wiggles" near the top/bottom
      - requires a full bottom->top->bottom traversal
      - uses robust quantile bands instead of absolute thresholds
    """
    # Smooth + normalize (robust)
    win = int(max(5, round(fps * 0.18)))
    if win % 2 == 0:
        win += 1
    s = _moving_average(signal, win)
    s_norm, _ = _normalize_robust(s)

    # Exercise-specific tuning (start here, then tune using mismatch list)
    if exercise == "deadlift":
        # deadlift: still strict, but not "1 rep only" strict
        bounds, stats = detect_reps_hysteresis(
            s_norm, fps,
            q_lo=0.15, q_hi=0.85,
            band_frac=0.10,
            min_rep_sec=0.70,
            min_amp_frac=0.30,
        )    elif exercise == "squat":
        bounds, stats = detect_reps_hysteresis(
            s_norm, fps,
            q_lo=0.20, q_hi=0.80,
            band_frac=0.12,
            min_rep_sec=0.75,
            min_amp_frac=0.35,
        )
    elif exercise in ("bench", "curl"):
        # usually faster, allow smaller amplitude
        bounds, stats = detect_reps_hysteresis(
            s_norm, fps,
            q_lo=0.20, q_hi=0.80,
            band_frac=0.14,
            min_rep_sec=0.55,
            min_amp_frac=0.28,
        )
    else:
        bounds, stats = detect_reps_hysteresis(s_norm, fps)

    per_rep: List[Dict[str, Any]] = []
    for (st, en) in bounds:
        if en <= st:
            continue
        seg = s_norm[st:en + 1]
        pk = st + int(np.argmax(seg))

        dur = (en - st) / max(fps, 1e-6)
        rom = float(np.max(seg) - np.min(seg))

        tempo_up = (pk - st) / max(fps, 1e-6)
        tempo_down = (en - pk) / max(fps, 1e-6)

        per_rep.append({
            "start_frame": int(st),
            "peak_frame": int(pk),
            "end_frame": int(en),
            "rom": float(rom),
            "duration_sec": float(dur),
            "tempo_up_sec": float(tempo_up),
            "tempo_down_sec": float(tempo_down),
        })

    n_reps = len(per_rep)
    avg_rom = float(np.mean([r["rom"] for r in per_rep])) if per_rep else 0.0
    avg_dur = float(np.mean([r["duration_sec"] for r in per_rep])) if per_rep else 0.0

    return {
        "n_reps": int(n_reps),
        "avg_rom": float(avg_rom),
        "avg_duration_sec": float(avg_dur),
        "per_rep": per_rep,
        "avg_angle_rom": None,
    }

def process_exercise(exercise: str, processed_root: Path, max_videos: Optional[int] = None) -> None:
    pose_dir = processed_root / "pose" / exercise
    metrics_dir = processed_root / "metrics" / exercise
    metrics_dir.mkdir(parents=True, exist_ok=True)

    npz_files = sorted(pose_dir.glob("*.npz"))
    if not npz_files:
        print(f"[WARN] No NPZ pose files for {exercise} under {pose_dir}")
        return

    if max_videos is not None:
        npz_files = npz_files[:max_videos]

    for npz_path in npz_files:
        stem = npz_path.stem
        meta_path = pose_dir / f"{stem}_meta.json"
        fps = _load_meta_fps(meta_path, default=30.0)

        out_path = metrics_dir / f"{stem}_metrics.json"

        pose_data = np.load(npz_path)["pose"]  # (T,33,4)

        signal = build_signal(pose_data, exercise)
        if not np.isfinite(signal).any():
            print(f"[WARN] All-NaN signal for {exercise} {npz_path.name}")
            payload = {
                "exercise": exercise,
                "video": None,
                "source_npz": str(npz_path),
                "fps": float(fps),
                "n_frames": int(pose_data.shape[0]),
                "n_reps": 0,
                "avg_rom": 0.0,
                "avg_duration_sec": 0.0,
                "avg_angle_rom": None,
                "per_rep": [],
            }
            out_path.write_text(json.dumps(payload, indent=2), encoding="utf-8")
            continue

        rep_metrics = compute_rep_metrics(signal, fps=fps, exercise=exercise)

        payload = {
            "exercise": exercise,
            "video": None,
            "source_npz": str(npz_path),
            "fps": float(fps),
            "n_frames": int(pose_data.shape[0]),
            **rep_metrics,
        }

        out_path.write_text(json.dumps(payload, indent=2), encoding="utf-8")
        print(f"[OK] {exercise}: {stem} → {payload['n_reps']} reps")


def main() -> None:
    parser = argparse.ArgumentParser(description="Compute simple rep metrics from pose NPZ files.")
    parser.add_argument(
        "--exercise",
        type=str,
        default="all",
        help="One of bench,squat,curl,deadlift,all (default: all)",
    )
    parser.add_argument(
        "--processed-root",
        type=str,
        default="data/processed",
        help="Root folder that contains pose/ and metrics/ subfolders.",
    )
    parser.add_argument(
        "--max-videos",
        type=int,
        default=None,
        help="Optional limit on number of videos per exercise for testing.",
    )
    args = parser.parse_args()

    processed_root = Path(args.processed_root)
    ex = args.exercise.lower().strip()

    if ex == "all":
        for e in VALID_EXERCISES:
            process_exercise(e, processed_root, max_videos=args.max_videos)
    elif ex in VALID_EXERCISES:
        process_exercise(ex, processed_root, max_videos=args.max_videos)
    else:
        raise SystemExit(f"Invalid --exercise {args.exercise}. Use one of {VALID_EXERCISES} or all.")



def detect_reps_hysteresis(signal: np.ndarray, fps: float, *,
                           q_lo: float = 0.20, q_hi: float = 0.80,
                           band_frac: float = 0.15,
                           min_rep_sec: float = 0.8,
                           min_amp_frac: float = 0.35) -> Tuple[List[Tuple[int,int]], List[Dict[str,float]]]:
    """
    Robust rep segmentation using hysteresis + full-cycle enforcement.

    Returns:
      rep_bounds: list of (start_idx, end_idx) for each rep cycle
      rep_stats: list of per-rep dicts (amp, dur_sec)
    """
    s = np.asarray(signal, dtype=float)
    x = np.arange(len(s))
    mask = np.isfinite(s)
    if mask.sum() < max(10, len(s) * 0.1):
        return [], []

    # interpolate missing
    s = np.interp(x, x[mask], s[mask])

    # light smoothing (moving average)
    w = int(max(5, round(fps * 0.15)))  # ~150ms
    if w % 2 == 0:
        w += 1
    s = np.convolve(s, np.ones(w)/w, mode="same")

    lo = float(np.quantile(s, q_lo))
    hi = float(np.quantile(s, q_hi))
    amp = hi - lo
    if not np.isfinite(amp) or amp <= 1e-9:
        return [], []

    bottom_th = lo + band_frac * amp
    top_th    = hi - band_frac * amp
    min_amp   = min_amp_frac * amp
    min_len   = int(max(1, round(min_rep_sec * fps)))

    state = "seek_bottom"  # seek_bottom -> seek_top -> seek_bottom2 (complete)
    rep_start = None
    rep_bounds = []
    rep_stats  = []

    last_top_idx = None

    for i, v in enumerate(s):
        if state == "seek_bottom":
            if v <= bottom_th:
                rep_start = i
                state = "seek_top"

        elif state == "seek_top":
            if v >= top_th:
                last_top_idx = i
                state = "seek_bottom2"

        elif state == "seek_bottom2":
            if v <= bottom_th:
                end_idx = i
                if rep_start is not None and last_top_idx is not None:
                    dur = end_idx - rep_start
                    rep_amp = abs(float(s[last_top_idx] - s[rep_start]))
                    if dur >= min_len and rep_amp >= min_amp:
                        rep_bounds.append((rep_start, end_idx))
                        rep_stats.append({"dur_sec": dur / fps, "amp": rep_amp})
                # reset for next cycle
                rep_start = i
                last_top_idx = None
                state = "seek_top"

    return rep_bounds, rep_stats


if __name__ == "__main__":
    main()

